{
  "name": "pi-web-ui",
  "version": "0.7.0",
  "type": "module",
  "description": "a webui for pi.dev",
  "keywords": [
    "pi-package"
  ],
  "license": "GPL-3.0-or-later",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/furkan-bilgin/pi-web-ui.git"
  },
  "homepage": "https://github.com/furkan-bilgin/pi-web-ui#readme",
  "bugs": {
    "url": "https://github.com/furkan-bilgin/pi-web-ui/issues"
  },
  "main": "dist/server/index.js",
  "bin": {
    "pi-web-ui": "dist/server/index.js"
  },
  "pi": {
    "extensions": [
      "src/extension/index.ts"
    ]
  },
  "files": [
    "dist",
    "public",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev:client": "vite",
    "dev:server": "tsc --watch",
    "dev": "concurrently \"npm:dev:client\" \"npm:dev:server\"",
    "build:client": "vite build",
    "build:server": "tsc --project tsconfig.server.json && node scripts/postbuild.mjs",
    "build": "npm run build:client && npm run build:server",
    "prepack": "npm run build",
    "start": "node dist/server/index.js",
    "test": "npm run build:server && node --test test/*.test.mjs"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.72",
    "@ai-sdk/react": "^3.0.209",
    "@base-ui/react": "^1.5.0",
    "@earendil-works/pi-coding-agent": "^0.79.8",
    "@fontsource-variable/geist": "^5.2.9",
    "@tailwindcss/vite": "^4.3.1",
    "@vitejs/plugin-react": "^4.5.2",
    "ai": "^6.0.207",
    "autoprefixer": "^10.5.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.40.0",
    "katex": "^0.17.0",
    "lucide-react": "^1.20.0",
    "marked": "^18.0.5",
    "next-themes": "^0.4.6",
    "postcss": "^8.5.15",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-markdown": "^10.1.0",
    "rehype-katex": "^7.0.1",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "remark-math-extended": "^6.1.0",
    "remeda": "2",
    "shadcn": "^4.11.0",
    "shiki": "^4.2.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.1",
    "tw-animate-css": "^1.4.0",
    "use-stick-to-bottom": "^1.1.6",
    "vite": "^6.3.5",
    "ws": "^8.18.3",
    "zod": "^4.4.3",
    "zustand": "^5.0.5"
  },
  "devDependencies": {
    "@types/node": "^25.6.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "concurrently": "^9.1.2",
    "typescript": "^6.0.3"
  }
}
